# Spotted - Umgebungsvariablen
#
# Kopiere diese Datei zu .env.local und trage Keys ein, sobald Phase 6
# (echte API-Integration) ansteht. Solange diese Variablen leer/nicht
# gesetzt sind, laufen /api/analyze und der Verlauf weiterhin im
# Dummy-Fallback-Modus (siehe docs/technical-architecture.md) - es entstehen
# keine Kosten und keine externen Aufrufe.

# Produktsuche / Preisvergleich (SerpAPI Google Lens API)
SERPAPI_KEY=

# Vision-API (Produkterkennung) - mindestens einen der folgenden Keys setzen
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
